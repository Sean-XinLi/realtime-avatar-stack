[Unit]
Description=Streaming Video Server (User)
After=default.target

[Service]
Type=simple
WorkingDirectory=%h/streaming_video_project/streaming_video_server
EnvironmentFile=%h/streaming_video_project/streaming_video_server/.env.server
ExecStart=%h/streaming_video_project/streaming_video_server/scripts/run_server.sh
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
